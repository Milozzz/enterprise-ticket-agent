# ============================================================
# Enterprise Ticket Agent — 环境变量模板
# 复制为 .env 后填入真实值，docker-compose up -d 即可一键启动
# ============================================================

# ── 数据库 (PostgreSQL) ─────────────────────────────────────
POSTGRES_USER=ticketuser
POSTGRES_PASSWORD=ticketpass
POSTGRES_DB=ticketdb
# compose 内部自动拼接；本地开发可改为 sqlite
DATABASE_URL=postgresql+asyncpg://ticketuser:ticketpass@postgres:5432/ticketdb

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── 大模型 (Google Gemini) ──────────────────────────────────
GOOGLE_API_KEY=<your-google-api-key>

# ── 可观测性 - Langfuse (可选) ──────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── 邮件通知 (Gmail, 可选) ──────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── 应用配置 ────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
FRONTEND_ORIGIN=http://localhost:3000
RISK_THRESHOLD_AMOUNT=500.0
SIMULATE_DATABASE_DOWN=false

# ── 前端 ────────────────────────────────────────────────────
# 浏览器端请求后端的地址（构建时内联）
NEXT_PUBLIC_API_URL=http://localhost:8000
